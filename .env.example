# Supabase (Client-side — used by popup)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Server-side — NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CRM Password (Server-side only — set in Vercel Dashboard)
CRM_PASSWORD=

# JWT signing secret (Server-side only — must be a separate random value from
# CRM_PASSWORD, at least 32 characters. Generate with: openssl rand -base64 32)
JWT_SECRET=
